# =============================================================================
# HashQuant 配置模板
# 使用：cp .env.example .env，然后填入真实 Key
# ⚠️  .env 包含私钥，不要提交到 git！
# =============================================================================

# ── Binance 生产网 ─────────────────────────────────────────────────────────────
# 申请：https://www.binance.com → 用户中心 → API 管理
BINANCE_API_KEY=
BINANCE_SECRET=

# ── Binance 测试网（与生产网独立，单独申请）────────────────────────────────────
# 申请：https://testnet.binance.vision  用 GitHub 账号登录后生成
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=

# ── OKX（生产网与模拟盘共用同一组 Key）────────────────────────────────────────
# 申请：https://www.okx.com → 账户 → API
# Passphrase 是创建 API 时自己设置的密码
OKX_API_KEY=
OKX_SECRET=
OKX_PASSPHRASE=

# ── Coinbase Advanced Trade ────────────────────────────────────────────────────
# 申请：https://www.coinbase.com → 设置 → API
COINBASE_API_KEY=
COINBASE_SECRET=

# Coinbase 沙箱（与生产网独立）
# 申请：https://public.sandbox.exchange.coinbase.com
COINBASE_SANDBOX_KEY=
COINBASE_SANDBOX_SECRET=

# ── Polymarket ─────────────────────────────────────────────────────────────────
# 申请：https://docs.polymarket.com/#authentication
POLY_API_KEY=
POLY_SECRET=

# ── 代理设置（中国大陆访问 testnet 需要）─────────────────────────────────────────
# 格式：http://127.0.0.1:端口号  （Clash 默认 7890，v2ray 默认 10809）
# 留空则不使用代理
HTTPS_PROXY=http://127.0.0.1:7890

# ── 日志级别 ───────────────────────────────────────────────────────────────────
RUST_LOG=info
